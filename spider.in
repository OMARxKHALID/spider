#!/usr/bin/env python3
import os
import sys
import signal

# Ensure we use the venv if available relative to the script's physical location
script_dir = os.path.dirname(os.path.realpath(__file__))
venv_python = os.path.join(script_dir, '..', '.venv', 'bin', 'python3')
if os.path.exists(venv_python) and sys.executable != venv_python:
    os.execl(venv_python, venv_python, *sys.argv)

pkgdatadir = '@DATADIR@/@PACKAGE_NAME@'
if os.path.exists(pkgdatadir):
    sys.path.insert(0, pkgdatadir)

srcdir = os.path.join(os.path.dirname(__file__), '..', 'src')
if os.path.exists(os.path.join(srcdir, 'spider')):
    sys.path.insert(0, srcdir)

from spider.main import main

if __name__ == '__main__':
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    sys.exit(main())
